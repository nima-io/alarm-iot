    {"id":"tpl_events","type":"ui_template","z":"flow_main","group":"grp_events","name":"Event Log","order":1,"width":"12","height":"6","format":"<div style='height:240px;overflow-y:auto;padding:4px'><p ng-if='!msg||!msg.payload||msg.payload.length===0' style='color:#888;font-style:italic;padding:8px'>No events yet.</p><div ng-repeat='e in msg.payload track by $index' style='padding:3px 6px;border-bottom:1px solid #333;font-family:monospace;font-size:0.85em;color:#ccc'>{{e}}</div></div>","storeOutMessages":true,"fwdInMessages":true,"resendOnRefresh":true,"templateScope":"local","x":760,"y":360,"wires":[[]]}
