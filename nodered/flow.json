    {"id":"txt_kitb_online","type":"ui_text","z":"flow_main","group":"grp_kits","order":2,"width":"3","height":"1","name":"Kit B Online","label":"Kit B","format":"{{msg.payload}}","layout":"row-spread","className":"","x":560,"y":740,"wires":[]},
    {"id":"mqtt_heartbeat","type":"mqtt in","z":"flow_main","name":"heartbeat","topic":"alarm/heartbeat/+","qos":"0","datatype":"utf8","broker":"mqtt_broker","x":110,"y":820,"wires":[["fn_presence"]]},
    {"id":"fn_presence","type":"function","z":"flow_main","name":"Presence tracker","func":"var kitA = msg.topic.indexOf('kit_a') >= 0;\nvar now = Date.now();\nflow.set(kitA ? 'hb_kit_a' : 'hb_kit_b', now);\nvar ha = flow.get('hb_kit_a') || 0;\nvar hb = flow.get('hb_kit_b') || 0;\nvar STALE = 12000;\nreturn [\n    {payload: (now - ha > STALE) ? 'STALE' : 'LIVE'},\n    {payload: (now - hb > STALE) ? 'STALE' : 'LIVE'}\n];","outputs":2,"noerr":0,"initialize":"","finalize":"","libs":[],"x":330,"y":820,"wires":[["txt_kita_live"],["txt_kitb_live"]]},
    {"id":"txt_kita_live","type":"ui_text","z":"flow_main","group":"grp_kits","order":3,"width":"3","height":"1","name":"Kit A Live","label":"Kit A live","format":"{{msg.payload}}","layout":"row-spread","className":"","x":560,"y":800,"wires":[]},
    {"id":"txt_kitb_live","type":"ui_text","z":"flow_main","group":"grp_kits","order":4,"width":"3","height":"1","name":"Kit B Live","label":"Kit B live","format":"{{msg.payload}}","layout":"row-spread","className":"","x":560,"y":840,"wires":[]},
    {"id":"mqtt_telemetry","type":"mqtt in","z":"flow_main","name":"telemetry","topic":"alarm/+/telemetry","qos":"0","datatype":"utf8","broker":"mqtt_broker","x":110,"y":940,"wires":[["fn_telem_rtr"]]},
    {"id":"fn_telem_rtr","type":"function","z":"flow_main","name":"Telemetry router","func":"var kitA = msg.topic.indexOf('kit_a') >= 0;\nvar series = kitA ? 'Kit A' : 'Kit B';\nvar ts = Date.now();\nvar d;\ntry { d = typeof msg.payload === 'string' ? JSON.parse(msg.payload) : msg.payload; } catch(e) { return null; }\nfunction pt(v) { return [{series:[series], data:[[{x:ts, y:parseFloat(v)||0}]], labels:[series]}]; }\nreturn [\n    {payload: pt(d.temp)},\n    {payload: pt(d.hum)},\n    {payload: pt(d.pres)},\n    {payload: pt(d.lux)}\n];","outputs":4,"noerr":0,"initialize":"","finalize":"","libs":[],"x":330,"y":940,"wires":[["chart_temp"],["chart_hum"],["chart_pres"],["chart_lux"]]},
    {"id":"chart_temp","type":"ui_chart","z":"flow_main","group":"grp_telem","name":"Temperature","order":1,"width":"6","height":"4","label":"Temperature (\u00b0C)","chartType":"line","legend":"true","xformat":"HH:mm","interpolate":"linear","nodata":"No data","dot":false,"ymin":"","ymax":"","removeOlder":"30","removeOlderUnit":"60","cutout":0,"useOneColor":false,"useUTC":false,"colors":["#1f77b4","#ff7f0e","#2ca02c","#d62728","#9467bd","#8c564b","#e377c2","#7f7f7f","#bcbd22","#17becf"],"outputs":1,"useDifferentColor":false,"x":560,"y":900,"wires":[[]]},
