    {"id":"fn_state_fmt","type":"function","z":"flow_main","name":"State badge","func":"try {\n    var d = typeof msg.payload === 'string' ? JSON.parse(msg.payload) : msg.payload;\n    msg.payload = d.state || 'UNKNOWN';\n} catch(e) { msg.payload = 'UNKNOWN'; }\nreturn msg;","outputs":1,"noerr":0,"initialize":"","finalize":"","libs":[],"x":330,"y":620,"wires":[["tpl_state_badge"]]},
    {"id":"tpl_state_badge","type":"ui-template","z":"flow_main","group":"grp_ctrl","name":"State Badge","order":1,"width":"6","height":"3","format":"<template>\n  <div style=\"padding:16px;text-align:center\">\n    <span :style=\"{\n      display: 'inline-block',\n      padding: '16px 24px',\n      borderRadius: '12px',\n      fontSize: '2.2em',\n      fontWeight: 'bold',\n      color: 'white',\n      background: state === 'DISARMED' ? '#22aa44' : state === 'ARMED' ? '#2244cc' : state === 'PRE_ALARM' ? '#ff8800' : '#cc2222'\n    }\">{{ state }}</span>\n  </div>\n</template>\n\n<script>\n  export default {\n    data() { return { state: '--' } },\n    methods: {\n      onMsgReceived (msg) { this.state = msg.payload || '--' }\n    }\n  }\n</script>","storeOutMessages":true,"fwdInMessages":true,"resendOnRefresh":true,"templateScope":"local","className":"","x":560,"y":620,"wires":[[]]},
    {"id":"mqtt_online","type":"mqtt in","z":"flow_main","name":"online","topic":"alarm/+/online","qos":"0","datatype":"utf8","broker":"mqtt_broker","x":110,"y":720,"wires":[["fn_online_rtr"]]},
    {"id":"fn_online_rtr","type":"function","z":"flow_main","name":"Online router","func":"var kitA = msg.topic.indexOf('kit_a') >= 0;\nvar on = (String(msg.payload) === '1');\nvar out = {payload: on ? 'ONLINE' : 'OFFLINE'};\nreturn kitA ? [out, null] : [null, out];","outputs":2,"noerr":0,"initialize":"","finalize":"","libs":[],"x":330,"y":720,"wires":[["txt_kita_online"],["txt_kitb_online"]]},
