    {"id":"mqtt_dfail","type":"mqtt in","z":"flow_main","name":"defuse_fail","topic":"alarm/kit_b/event/defuse_fail","qos":"0","datatype":"utf8","broker":"mqtt_broker","x":110,"y":320,"wires":[["fn_fsm"]]},
    {"id":"fn_fsm","type":"function","z":"flow_main","name":"FSM","func":"var state = flow.get('state') || 'DISARMED';\nvar now = Date.now();\nvar newState = state;\nvar logMsg = null;\nvar timerMsg = null;\nvar topic = msg.topic || '';\n\nif (msg._isTimer === true) {\n    if (state === 'PRE_ALARM') { newState = 'TRIGGERED'; logMsg = 'Entry delay expired'; }\n} else if (topic === 'alarm/command/arm') {\n    if (state === 'DISARMED') { newState = 'ARMED'; logMsg = 'Arm command'; }\n} else if (topic === 'alarm/command/disarm') {\n    newState = 'DISARMED'; logMsg = 'Disarm (admin override)'; timerMsg = {reset: true};\n} else if (topic === 'alarm/kit_a/event/motion') {\n    if (state === 'ARMED') { newState = 'PRE_ALARM'; logMsg = 'Motion detected (Kit A)'; timerMsg = {_isTimer: true, payload: 'entry_delay'}; }\n} else if (topic === 'alarm/kit_b/event/defused') {\n    if (state === 'PRE_ALARM' || state === 'TRIGGERED') { newState = 'DISARMED'; logMsg = 'DEFUSED!'; timerMsg = {reset: true}; }\n} else if (topic === 'alarm/kit_b/event/defuse_fail') {\n    logMsg = 'Defuse FAILED';\n}\n\nvar out1 = null, out2 = timerMsg, out3 = null;\n\nif (newState !== state) {\n    flow.set('state', newState);\n    out1 = {payload: JSON.stringify({state: newState, since: now})};\n}\n\nif (logMsg) {\n    var tag = (newState !== state) ? newState : state;\n    out3 = {payload: new Date().toLocaleTimeString() + '  ' + logMsg + '  [' + tag + ']'};\n}\n\nreturn [out1, out2, out3];","outputs":3,"noerr":0,"initialize":"","finalize":"","libs":[],"x":360,"y":200,"wires":[["out_state"],["delay_15s"],["fn_event_log"]]},
    {"id":"delay_15s","type":"delay","z":"flow_main","name":"15 s Entry Delay","pauseType":"delay","timeout":"15","timeoutUnits":"seconds","rate":"1","nbRateUnits":"1","rateUnits":"second","randomFirst":"1","randomLast":"5","randomUnits":"seconds","drop":false,"allowrate":false,"x":580,"y":280,"wires":[["fn_fsm"]]},
    {"id":"out_state","type":"mqtt out","z":"flow_main","name":"alarm/system/state","topic":"alarm/system/state","qos":"0","retain":"true","broker":"mqtt_broker","x":600,"y":160,"wires":[]},
    {"id":"fn_event_log","type":"function","z":"flow_main","name":"Event Log","func":"var log = flow.get('eventLog') || [];\nlog.unshift(msg.payload);\nif (log.length > 30) log.length = 30;\nflow.set('eventLog', log);\nmsg.payload = log;\nreturn msg;","outputs":1,"noerr":0,"initialize":"","finalize":"","libs":[],"x":580,"y":360,"wires":[["tpl_events"]]},
