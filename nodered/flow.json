    {"id":"mqtt_heartbeat","type":"mqtt in","z":"flow_main","name":"heartbeat","topic":"alarm/heartbeat/+","qos":"0","datatype":"utf8","broker":"mqtt_broker","x":110,"y":820,"wires":[["fn_presence"]]},
    {"id":"fn_presence","type":"function","z":"flow_main","name":"Presence tracker","func":"var kitA = msg.topic.indexOf('kit_a') >= 0;\nvar now = Date.now();\nflow.set(kitA ? 'hb_kit_a' : 'hb_kit_b', now);\nvar ha = flow.get('hb_kit_a') || 0;\nvar hb = flow.get('hb_kit_b') || 0;\nvar STALE = 12000;\nreturn [\n    {payload: (now - ha > STALE) ? 'STALE' : 'LIVE'},\n    {payload: (now - hb > STALE) ? 'STALE' : 'LIVE'}\n];","outputs":2,"noerr":0,"initialize":"","finalize":"","libs":[],"x":330,"y":820,"wires":[["txt_kita_live"],["txt_kitb_live"]]},
