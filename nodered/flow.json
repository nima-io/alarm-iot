    {"id":"tpl_events","type":"ui-template","z":"flow_main","group":"grp_events","name":"Event Log","order":1,"width":"12","height":"6","format":"<template>\n  <div style=\"height:240px;overflow-y:auto;padding:4px\">\n    <p v-if=\"!events.length\" style=\"color:#888;font-style:italic;padding:8px\">No events yet.</p>\n    <div v-for=\"(e, i) in events\" :key=\"i\" style=\"padding:3px 6px;border-bottom:1px solid #333;font-family:monospace;font-size:0.85em;color:#ccc\">{{ e }}</div>\n  </div>\n</template>\n\n<script>\n  export default {\n    data() { return { events: [] } },\n    methods: {\n      onMsgReceived (msg) { this.events = msg.payload || [] }\n    }\n  }\n</script>","storeOutMessages":true,"fwdInMessages":true,"resendOnRefresh":true,"templateScope":"local","className":"","x":760,"y":360,"wires":[[]]}
