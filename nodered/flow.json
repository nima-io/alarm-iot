    {"id":"mqtt_telemetry","type":"mqtt in","z":"flow_main","name":"telemetry","topic":"alarm/+/telemetry","qos":"0","datatype":"utf8","broker":"mqtt_broker","x":110,"y":940,"wires":[["fn_telem_rtr"]]},
    {"id":"fn_telem_rtr","type":"function","z":"flow_main","name":"Telemetry router","func":"var kitA = msg.topic.indexOf('kit_a') >= 0;\nvar series = kitA ? 'Kit A' : 'Kit B';\nvar ts = Date.now();\nvar d;\ntry { d = typeof msg.payload === 'string' ? JSON.parse(msg.payload) : msg.payload; } catch(e) { return null; }\nreturn [\n    {topic: series, payload: {x: ts, y: parseFloat(d.temp)  || 0}},\n    {topic: series, payload: {x: ts, y: parseFloat(d.hum)   || 0}},\n    {topic: series, payload: {x: ts, y: parseFloat(d.pres)  || 0}},\n    {topic: series, payload: {x: ts, y: parseFloat(d.lux)   || 0}}\n];","outputs":4,"noerr":0,"initialize":"","finalize":"","libs":[],"x":330,"y":940,"wires":[["chart_temp"],["chart_hum"],["chart_pres"],["chart_lux"]]},
